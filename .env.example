# =========================================================
# FIFA WC 2026 Predictions - Environment configuration
# Copy this file to ".env" and fill in real values.
# Never commit your real .env file.
# =========================================================

# Local web server port
PORT=3000

# Which live-score provider the proxy uses.
# Options shipped out of the box:
#   mock          -> deterministic fake matches, no key needed (great for demo)
#   footballdata  -> https://www.football-data.org (X-Auth-Token)
#   apifootball   -> https://www.api-football.com  (api-sports.io key)
#   sportmonks    -> placeholder, not implemented yet
API_PROVIDER=mock

# Your provider key (leave blank when API_PROVIDER=mock)
API_KEY=

# Optional override of the upstream base URL
# football-data:  https://api.football-data.org/v4
# api-football:   https://v3.football.api-sports.io
API_BASE_URL=

# Competition / league id at your provider
# football-data:  WC  (FIFA World Cup)
# api-football:   1   (World Cup league id)
API_COMPETITION_ID=

# api-football specific
API_SEASON=2026

# Server-side cache TTL in milliseconds. Helps avoid rate limits.
CACHE_TTL_MS=30000

# =========================================================
# Predictions storage
# =========================================================
# If GOOGLE_SHEET_ID is set, the server stores group predictions in Google
# Sheets. If it's blank, the server falls back to data/predictions.json
# (good for local dev; NOT persistent on Render's free tier).

# 1) Create a Google Sheet, copy its ID from the URL (the long string between /d/ and /edit)
GOOGLE_SHEET_ID=

# 2) Create a Google Cloud service account, download its JSON key file,
#    then base64-encode the whole file and paste here. On macOS/Linux:
#      base64 -i sa-key.json | tr -d '\n'
#    On Windows PowerShell:
#      [Convert]::ToBase64String([IO.File]::ReadAllBytes("sa-key.json"))
#    Share the spreadsheet with the service account's email (Editor access).
GOOGLE_SA_KEY_BASE64=

# Optional: tab/sheet names within the spreadsheet (defaults shown).
PREDICTIONS_SHEET_NAME=Predictions
RESULTS_SHEET_NAME=Results
